---
const { contacte } = Astro.props;
---
<footer id="peu">
  <div class="links">
    <p>Contacte: <a href={`mailto:${contacte.email}`}>{contacte.email}</a></p>
    <div class="socials">
      <a href={contacte.linkedin}>LinkedIn</a>
      <a href={contacte.github}>GitHub</a>
    </div>
  </div>
  <p class="copy">© 2026 {contacte.location}</p>
</footer>

<style>
  footer { margin-top: 4rem; padding: 2rem 0; border-top: 1px solid #eee; font-family: sans-serif; color: #666; }
  .links { display: flex; justify-content: space-between; align-items: center; }
  .socials { display: flex; gap: 1rem; }
  a { color: #333; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .copy { font-size: 0.8rem; margin-top: 1rem; }
</style>