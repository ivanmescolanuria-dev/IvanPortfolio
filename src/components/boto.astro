---
const { text, href } = Astro.props;
---
<a href={href} class="boto">{text}</a>

<style>
  .boto { display: inline-block; padding: 0.6rem 1.2rem; border-radius: 999px; border: 1px solid #0f172a; text-decoration: none; color: #0f172a; font-weight: 500; }
  .boto:hover { background-color: #0f172a; color: white; }
</style>