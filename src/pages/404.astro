---
import Layout from "../layouts/Layout.astro";
import Boto from "../components/boto.astro";
---

<Layout title="404 - Pàgina no trobada">
  <main class="error-container">
    <div class="content">
      <span class="error-code">404</span>
      <h1>Vaja! T'has perdut?</h1>
      <p>
        La pàgina que estàs buscant no existeix o ha estat moguda a una altra ruta. 
        No et preocupis, pots tornar a l'inici amb el botó de sota.
      </p>
      <div class="actions">
        <Boto text="Tornar a l'Inici" href="/" />
      </div>
    </div>
  </main>
</Layout>

<style>
  .error-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    text-align: center;
    padding: 2rem;
  }

  .error-code {
    display: block;
    font-size: 8rem;
    font-weight: 900;
    color: #e2e8f0; /* Un color gris suau */
    line-height: 1;
  }

  h1 {
    font-size: 2.5rem;
    color: #0f172a;
    margin-top: -2rem;
    margin-bottom: 1rem;
  }

  p {
    font-size: 1.2rem;
    color: #64748b;
    max-width: 500px;
    margin: 0 auto 2rem auto;
  }

  .actions {
    display: flex;
    justify-content: center;
  }
</style>